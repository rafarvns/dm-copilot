{
  "name": "dm-copilot",
  "version": "0.1.0",
  "description": "Assistente desktop para mestres de RPG de mesa - Crie e gerencie suas campanhas com facilidade",
  "main": "out/main/index.js",
  "author": "DM Copilot Team",
  "license": "MIT",
  "icon": "./src/assets/icons/logo_ico.ico",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/copy-database.js",
    "preview": "electron-vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "build:win": "node scripts/copy-database.js && electron-vite build && electron-builder --win",
    "build:linux": "node scripts/copy-database.js && electron-vite build && electron-builder --linux",
    "build:mac": "node scripts/copy-database.js && electron-vite build && electron-builder --mac",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@3d-dice/dice-box": "^1.1.4",
    "better-sqlite3": "^12.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
